project_name = "code-intelligence-platform"
environment  = "dev"
aws_region   = "us-west-2"

# CI workspace EC2 instance (jay-ubuntu-workspace-ci-workspace)
workspace_username        = "ubuntu"
workspace_project_name    = "jay-ubuntu-workspace"
workspace_vscode_password = "CHANGE_ME"

# otasdp-poc workspace (access via SSM Session Manager, no SSH key pair)
otasdp_poc_allowed_cidr_blocks = ["1.2.3.4/32"] # set to your real source IP(s) before apply
otasdp_poc_vscode_password     = "CHANGE_ME"
