# =============================================================================
# Code Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Configuration ---
# Providers: ollama | groq | openai | huggingface | bedrock
LLM_PROVIDER=ollama
LLM_MAX_TOKENS=1024           # Max tokens in generated response (output)
LLM_TIMEOUT=120               # Seconds to wait for LLM response
LLM_RETRY_MAX_ATTEMPTS=3      # Retries for 429/timeout/transient failures
LLM_RETRY_BACKOFF_SECONDS=2.0 # Base backoff in seconds (attempt multiplier)
# Optional: use LangChain wrapper for OpenAI/Groq providers
LLM_USE_LANGCHAIN=false

# --- Prompt Size Budgeting (prevents 413 / context_length_exceeded) ---
# Scans can produce hundreds of findings or dependency entries with very large
# description / reference fields. These limits cap what gets sent to the LLM
# without losing the highest-severity items. Lower for free-tier providers
# (Groq), raise for high-context providers (OpenAI gpt-4o-mini, Bedrock Claude).
LLM_PROMPT_MAX_ITEMS=25       # Top-K items kept (sorted by severity)
LLM_PROMPT_MAX_STR_LEN=400    # Per-string field truncation (chars)
LLM_PROMPT_MAX_CHARS=24000    # Hard cap on rendered prompt size (~6k tokens)
LLM_PROMPT_FILE_MAX_CHARS=12000  # Per-file budget when embedding source/test files (PR remediation)

# --- Ollama (local, open-source, default for development) ---
OLLAMA_MODEL=llama3.2:1b      # 1b recommended for CPU, 3b+ for GPU
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_NUM_CTX=8192            # Context window (input + output tokens)

# --- Groq (FREE cloud, ~500 tok/s, recommended) ---
# Sign up free: https://console.groq.com → API Keys
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your-key-here
# GROQ_MODEL=llama-3.1-8b-instant
# Available models: llama-3.1-8b-instant, llama-3.3-70b-versatile, mixtral-8x7b-32768

# --- OpenAI (or any OpenAI-compatible API) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Hugging Face Inference API ---
# Sign up free: https://huggingface.co/settings/tokens
# LLM_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=hf_your-key-here
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# --- AWS Bedrock ---
# LLM_PROVIDER=bedrock
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Optional for cross-region / provisioned throughput profile:
# BEDROCK_INFERENCE_PROFILE_ARN=arn:aws:bedrock:us-west-2:123456789012:inference-profile/your-profile

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_your_github_token_here

# --- Remediation Agent ---
# deterministic | nondeterministic
# deterministic: safe rule-based patches only
# nondeterministic: reserved for LLM patch generation workflow
REMEDIATION_MODE=deterministic
REMEDIATION_MAX_ATTEMPTS=2
REMEDIATION_MAX_FILES=3
POST_PR_REVIEW_ENABLED=true

# --- Vector Database (RAG) ---
VECTOR_DB_TYPE=faiss           # faiss | qdrant
VECTOR_DB_DIR=.vector_db       # Directory for FAISS index storage

# --- LangSmith Observability (optional) ---
# Enable tracing for scan/LLM runs in LangSmith
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=lsv2_pt_your-key-here
LANGSMITH_PROJECT=code-intelligence-platform
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Qdrant (uncomment if using Qdrant)
# VECTOR_DB_TYPE=qdrant
# QDRANT_URL=localhost
# QDRANT_PORT=6333
