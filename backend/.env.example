# =============================================================================
# Code Intelligence Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Configuration ---
LLM_PROVIDER=ollama           # ollama | openai | huggingface
OLLAMA_MODEL=llama3.2:3b      # Model name for Ollama
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (uncomment if using OpenAI)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Hugging Face (uncomment if using HF)
# LLM_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=hf_your-key-here
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_your_github_token_here

# --- Vector Database (RAG) ---
VECTOR_DB_TYPE=faiss           # faiss | qdrant
VECTOR_DB_DIR=.vector_db       # Directory for FAISS index storage

# Qdrant (uncomment if using Qdrant)
# VECTOR_DB_TYPE=qdrant
# QDRANT_URL=localhost
# QDRANT_PORT=6333
