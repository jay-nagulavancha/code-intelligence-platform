# =============================================================================
# .dockerignore — Code Intelligence Platform Backend
# =============================================================================
# NOTE: test files and scan_github_repo.py are intentionally NOT excluded here
# because the test and development stages need them.
# The production stage uses explicit COPY commands so these never land there.
# =============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment files — injected at runtime via docker-compose / AWS
.env

# Docker meta files
Dockerfile
.dockerignore

# Docs and diagrams (not needed in any image)
*.md
*.excalidraw
*.png
*.svg

# Scan output files (runtime artefacts, not source)
security_scan_summary.md
scan_report_*.json
security_scan_*.json
GITHUB_MCP_TEST_RESULTS.md

# Vector DB and temp repos (mounted as volumes at runtime)
.vector_db/
repos/
reports/

# Git
.git/
.gitignore
